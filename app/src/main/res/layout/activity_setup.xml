<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/night"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="نور"
            android:textSize="52sp"
            android:textStyle="bold"
            android:textColor="@color/gold"
            android:layout_marginTop="48dp"
            android:fontFamily="serif" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tagline"
            android:textSize="12sp"
            android:textColor="@color/textSecondary"
            android:letterSpacing="0.15"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="40dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/choose_addiction"
                android:textSize="13sp"
                android:textColor="@color/gold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="16dp" />

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:id="@+id/cardSmoking"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_addiction_card"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🚬" android:textSize="28sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="التدخين" android:textSize="13sp" android:textColor="@color/textPrimary" android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardAlcohol"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_addiction_card"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🍷" android:textSize="28sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الكحول" android:textSize="13sp" android:textColor="@color/textPrimary" android:layout_marginTop="4dp"/>
                </LinearLayout>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="12dp"/>

            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:id="@+id/cardGaming"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_addiction_card"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎮" android:textSize="28sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="إدمان الألعاب" android:textSize="12sp" android:textColor="@color/textPrimary" android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardSocial"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_addiction_card"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📱" android:textSize="28sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="السوشيال ميديا" android:textSize="12sp" android:textColor="@color/textPrimary" android:layout_marginTop="4dp"/>
                </LinearLayout>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="12dp"/>

            <!-- Row 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:id="@+id/cardShopping"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_addiction_card"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🛍️" android:textSize="28sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="التسوق القهري" android:textSize="12sp" android:textColor="@color/textPrimary" android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardPorn"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_addiction_card"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔒" android:textSize="28sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الإباحية" android:textSize="13sp" android:textColor="@color/textPrimary" android:layout_marginTop="4dp"/>
                </LinearLayout>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="12dp"/>

            <!-- Row 4 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:id="@+id/cardGambling"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_addiction_card"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎲" android:textSize="28sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="القمار" android:textSize="13sp" android:textColor="@color/textPrimary" android:layout_marginTop="4dp"/>
                </LinearLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"/>

            </LinearLayout>

            <Button
                android:id="@+id/btnStart"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:text="@string/start_journey"
                android:textColor="@color/night"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_gold"
                android:stateListAnimator="@null" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
