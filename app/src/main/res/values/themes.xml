<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.NoorRecovery" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/gold</item>
        <item name="colorPrimaryVariant">@color/amber</item>
        <item name="colorOnPrimary">@color/night</item>
        <item name="colorSecondary">@color/teal</item>
        <item name="colorOnSecondary">@color/night</item>
        <item name="android:colorBackground">@color/night</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/textPrimary</item>
        <item name="android:windowBackground">@color/night</item>
        <item name="android:statusBarColor">@color/night</item>
        <item name="android:navigationBarColor">@color/night</item>
        <item name="android:layoutDirection">rtl</item>
        <item name="android:textColorPrimary">@color/textPrimary</item>
        <item name="android:textColorSecondary">@color/textSecondary</item>
        <item name="bottomNavigationStyle">@style/BottomNavStyle</item>
    </style>

    <style name="BottomNavStyle" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/surface</item>
        <item name="itemIconTint">@color/nav_item_color</item>
        <item name="itemTextColor">@color/nav_item_color</item>
        <item name="itemActiveIndicatorStyle">@style/NavIndicator</item>
    </style>

    <style name="NavIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">#2A1848</item>
    </style>

    <style name="SplashTheme" parent="Theme.NoorRecovery">
        <item name="android:windowBackground">@color/night</item>
    </style>
</resources>
