<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient android:startColor="#00A88A" android:endColor="#008870" android:angle="135"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <gradient android:startColor="#00D4AA" android:endColor="#00A88A" android:angle="135"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
</selector>
