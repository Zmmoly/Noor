<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape>
            <solid android:color="#2A2010"/>
            <stroke android:width="1.5dp" android:color="#F5C842"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#201830"/>
            <stroke android:width="1dp" android:color="#4A3860"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#180E2E"/>
            <stroke android:width="1dp" android:color="#2A1848"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
</selector>
